# Auto-detect text files and normalize line endings to LF on commit
* text=auto eol=lf

# Explicitly LF for cross-platform-stable text files
*.md       text eol=lf
*.txt      text eol=lf
*.py       text eol=lf
*.js       text eol=lf
*.ts       text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.json     text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.toml     text eol=lf
*.sh       text eol=lf
*.bat      text eol=crlf
*.ps1      text eol=crlf

# Binary — git won't try to text-diff these
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.gz       binary
*.tar      binary
*.exe      binary
*.dll      binary
